{
  "name": "design-distill",
  "version": "0.3.0",
  "description": "Distill any website's design system into DESIGN.md, then generate code that actually matches",
  "type": "module",
  "bin": {
    "design-distill": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "skills",
    "bundled"
  ],
  "scripts": {
    "build": "tsdown",
    "prepare": "tsdown",
    "prepublishOnly": "tsdown",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "cli",
    "ai-agent",
    "claude-code",
    "design-distill"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muluk-m/design-distill"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
